generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id                String            @id @default(cuid())
  title             String
  amount            Decimal           @db.Decimal(10, 2)
  type              TransactionType
  date              DateTime
  status            TransactionStatus @default(COMPLETED)
  expectedAmount    Decimal?          @db.Decimal(10, 2)
  actualAmount      Decimal?          @db.Decimal(10, 2)
  expectedDate      DateTime?
  actualDate        DateTime?
  isFixed           Boolean           @default(false)
  isAdjustment      Boolean           @default(false)
  accountId         String?
  cardId            String?
  userId            String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  invoiceId         String?
  paymentMethod     String?
  category          String?
  installmentNumber Int?
  installmentTotal  Int?
  purchaseGroupId   String?
  account           accounts?         @relation(fields: [accountId], references: [id])
  card              cards?            @relation(fields: [cardId], references: [id])
  invoice           Invoice?          @relation(fields: [invoiceId], references: [id])
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([cardId])
  @@index([invoiceId])
  @@index([status])
  @@index([userId, status])
  @@index([expectedDate])
  @@index([actualDate])
  @@map("transactions")
}

model Invoice {
  id                String        @id @default(cuid())
  month             Int
  year              Int
  total             Decimal       @default(0) @db.Decimal(10, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  cardId            String
  userId            String
  paidAt            DateTime?
  closedAt          DateTime?
  paidFromAccountId String?
  status            InvoiceStatus @default(OPEN)
  card              cards         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  paidFromAccount   accounts?     @relation("PaidInvoiceAccount", fields: [paidFromAccountId], references: [id])
  transactions      Transaction[]
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, month, year])
  @@index([userId])
  @@index([cardId])
  @@map("invoices")
}

model RecurringTransaction {
  id            String          @id @default(cuid())
  title         String
  amount        Decimal         @db.Decimal(10, 2)
  type          TransactionType
  category      String?
  isFixed       Boolean         @default(false)
  paymentMethod String?
  accountId     String?
  cardId        String?
  userId        String
  dayOfMonth    Int
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  account       accounts?       @relation(fields: [accountId], references: [id])
  card          cards?          @relation(fields: [cardId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([cardId])
  @@map("recurring_transactions")
}

model accounts {
  id                    String                 @id @default(cuid())
  name                  String
  bank                  String?
  balance               Decimal                @default(0) @db.Decimal(10, 2)
  userId                String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  paidInvoices          Invoice[]              @relation("PaidInvoiceAccount")
  recurringTransactions RecurringTransaction[]
  transactions          Transaction[]
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model cards {
  id                    String                 @id @default(cuid())
  name                  String
  brand                 String?
  limit                 Decimal?               @db.Decimal(10, 2)
  monthlyLimit         Decimal?
  closingDay            Int?
  dueDay                Int?
  userId                String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  invoices              Invoice[]
  recurringTransactions RecurringTransaction[]
  transactions          Transaction[]
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum InvoiceStatus {
  OPEN
  PAID
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PLANNED
  COMPLETED
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String                 @unique
  password              String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  accounts              accounts[]
  cards                 cards[]
  transactions          Transaction[]
  invoices              Invoice[]
  recurringTransactions RecurringTransaction[]
  simulationHistories   SimulationHistory[]
}

model SimulationHistory {
  id                          String   @id @default(cuid())
  title                       String
  purchaseType                String
  totalAmount                 Float
  installmentCount            Int?
  installmentAmount           Float?
  recommendedCardName         String?
  recommendationStatus        String
  recommendationTitle         String
  recommendationReason        String
  lowestProjectedMonthLabel   String?
  lowestProjectedBalance      Float?
  limitUsagePercent           Float?
  remainingLimitAfterPurchase Float?
  selectedMonth               String?
  userId                      String
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
